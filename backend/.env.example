# ====================================
# Application Configuration
# ====================================
# Set to True for debug mode, must be False in production
DEBUG=True

# ====================================
# Database Configuration
# ====================================
# PostgreSQL database connection string
# Format: postgresql://username:password@host:port/database_name
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/construction_inventory

# ====================================
# Security & Key Configuration
# ====================================
# JWT token signing key, must use long and complex random string in production
SECRET_KEY=your-super-secret-jwt-key-change-this-in-production

# ====================================
# Optional Features Configuration
# ====================================
# Redis connection URL (for Celery background tasks, leave empty if not needed)
REDIS_URL=redis://localhost:6379/0
