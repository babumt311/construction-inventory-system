# Application Settings
DEBUG=True
APP_NAME=Construction Inventory System
APP_VERSION=1.0.0

# Database Settings
DATABASE_URL=postgresql://postgres:password@localhost:5432/construction_inventory

# Security
SECRET_KEY=your-secret-key-change-in-production-32-characters-minimum
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Upload Settings
MAX_UPLOAD_SIZE=10485760  # 10MB in bytes

# Redis (optional)
REDIS_URL=redis://localhost:6379/0

# CORS Origins (comma separated)
BACKEND_CORS_ORIGINS=["http://localhost:4200,http://localhost:3000,http://localhost:8080"]
